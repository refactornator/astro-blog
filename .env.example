# PostHog — browser SDK (PUBLIC_ prefix exposes to client via Astro)
PUBLIC_POSTHOG_API_KEY=phc_YOUR_PROJECT_KEY
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# PostHog — server-side Query API (harness only, never in browser)
# Note: Query API host may differ from browser SDK host.
# US cloud: https://us.posthog.com  |  EU cloud: https://eu.posthog.com
POSTHOG_API_HOST=https://us.posthog.com
POSTHOG_PERSONAL_API_KEY=phx_YOUR_PERSONAL_KEY
POSTHOG_PROJECT_ID=YOUR_PROJECT_ID

MIN_SESSIONS=5
AUTO_PUSH=false
