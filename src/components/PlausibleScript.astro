---
// Plausible Analytics integration using @plausible-analytics/tracker
// Automatically tracks page views, scroll depth, and user journeys
// Add your domains to the TRACKED_DOMAINS list below
---

<script>
  import { init } from "@plausible-analytics/tracker";

  // List of domains to track with Plausible
  const TRACKED_DOMAINS = [
    "refactornator.com",
    "liameveryday.com",
    "liamlindner.com",
    "liamlinder.com",
  ];

  // Determine which domain to use based on current hostname
  const currentHostname = window.location.hostname;
  const domainToTrack = TRACKED_DOMAINS.find((domain) =>
    currentHostname.includes(domain.split(".")[0]),
  );

  // Only initialize if current domain is in the tracked domains list
  if (domainToTrack) {
    init({
      domain: domainToTrack,
      captureOnLocalhost: false,
      outboundLinks: true,
      fileDownloads: true,
      formSubmissions: true,
    });
  }
</script>

