---
// Plausible Analytics integration using @plausible-analytics/tracker
// Automatically tracks page views, scroll depth, and user journeys
// All domains (CNAMEs) are tracked under the primary Cloudflare Pages domain
---

<script>
  import { init } from "@plausible-analytics/tracker";

  // Primary domain for Plausible (Cloudflare Pages domain)
  // All CNAMEs (refactornator.com, liameveryday.com, etc.) will be tracked under this domain
  const PRIMARY_DOMAIN = "astro-blog-9og.pages.dev";

  // Initialize Plausible with the primary domain
  // Plausible will automatically track all CNAMEs pointing to this domain
  init({
    domain: PRIMARY_DOMAIN,
    captureOnLocalhost: false,
    outboundLinks: true,
    fileDownloads: true,
    formSubmissions: true,
  });
</script>

