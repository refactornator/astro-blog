---
import { Icon } from "astro-icon/components";
import { metaData } from "../config";

const navItems: Record<string, { name: string }> = {
  "/": { name: "Home" },
  "/projects": { name: "Projects" },
  "/photos": { name: "Photos" },
};

// Get current page path
const currentPath = Astro.url.pathname;
---

<nav class="mb-2 py-5">
  <div class="flex flex-row items-center justify-between">
    <div class="flex items-center">
      <a href="/" class="text-3xl font-semibold text-[#1C1C1C] dark:text-[#D4D4D4]">
        {metaData.name}
      </a>
    </div>
    <div class="flex flex-row gap-4 ml-auto items-center">
      {
        Object.entries(navItems).map(([path, { name }]) => {
          const isActive = currentPath === path || (path !== "/" && currentPath.startsWith(path));
          return (
            <a
              href={path}
              data-prefetch="intent"
              class={`transition-all flex align-middle relative pb-1 ${
                isActive
                  ? "border-b-2 border-sapphire dark:border-solar text-sapphire dark:text-solar"
                  : "text-[#1C1C1C] dark:text-[#D4D4D4] hover:text-neutral-800 dark:hover:text-neutral-200"
              }`}>
              {name}
            </a>
          );
        })
      }
      <button
        id="theme-toggle"
        aria-label="Toggle theme"
        class="flex items-center justify-center transition-opacity duration-300 hover:opacity-90">
        <Icon
          name="fa6-solid:circle-half-stroke"
          class="h-[14px] w-[14px] text-[#1c1c1c] dark:text-[#D4D4D4]"
        />
      </button>
    </div>
  </div>
</nav>

<script is:inline>
  function setTheme(theme) {
    document.dispatchEvent(new CustomEvent("set-theme", { detail: theme }));
  }

  function toggleTheme() {
    const currentTheme = document.documentElement.getAttribute("data-theme");
    const newTheme = currentTheme === "dark" ? "light" : "dark";
    setTheme(newTheme);
  }

  document.addEventListener("astro:page-load", () => {
    document
      .getElementById("theme-toggle")
      .addEventListener("click", toggleTheme);
  });
</script>
