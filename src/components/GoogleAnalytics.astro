// Google Analytics 4
---
<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-ME24SJN4RE"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-ME24SJN4RE', { send_page_view: false });

  // Send page_view on every navigation (initial + client-side View Transitions)
  document.addEventListener('astro:page-load', function() {
    gtag('event', 'page_view', {
      page_title: document.title,
      page_location: window.location.href,
    });
  });
</script>
