---
import { Content } from "../../content/projects.md";
import Base from "../../layouts/Base.astro";

const title = "Projects";
const description = "Lessons learned from my work, side projects, and interests";
---

<Base title={title} description={description}>
  <section>
    <div class="prose prose-neutral dark:prose-invert max-w-none">
      <Content />
    </div>
  </section>
</Base>

<style>
  :global(h2) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  :global(h2::before) {
    content: "";
    display: inline-block;
    width: 1.5rem;
    height: 1.5rem;
  }

  :global(h2:nth-of-type(1)::before) {
    content: "✨";
    font-size: 1.5rem;
  }

  :global(h2:nth-of-type(2)::before) {
    content: "💼";
    font-size: 1.5rem;
  }

  :global(h2:nth-of-type(3)::before) {
    content: "🚀";
    font-size: 1.5rem;
  }
</style>
