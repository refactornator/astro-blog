---
import { Image } from "astro:assets";
import { socialLinks } from "../config";
import Base from "../layouts/Base.astro";
---

<Base>
  <section>
    <Image
      src="/profile.png"
      alt="Profile photo"
      class="rounded-full bg-gray-100 block lg:mt-5 mt-0 lg:mb-5 mb-10 mx-auto sm:float-right sm:ml-5 sm:mb-5 grayscale hover:grayscale-0"
      width={160}
      height={160}
    />

    <h1 class="mb-8 text-xl font-medium tracking-tight">Product Engineer</h1>

    <div class="prose prose-neutral dark:prose-invert">
      <p>
        I'm Liam, a software engineer living in San Francisco. I build AI-powered tools with strong product intuition—understanding what actually matters to users and shipping it. I care deeply about engineering best practices and believe that how something is built matters as much as what it does.
      </p>
      <p>
        Outside of work, I spend time performing improv theater, taking photographs, and writing essays. These practices keep me grounded and remind me what life is all about.
      </p>
      <p>
        Find me on <a href={socialLinks.github} target="_blank">GitHub</a> and
        <a href={socialLinks.substack} target="_blank">Substack</a>.
      </p>
    </div>
  </section>
</Base>
