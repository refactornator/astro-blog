---
interface Props {
  title?: string;
  description?: string;
  image?: string;
}

import { ClientRouter } from "astro:transitions";
import Themes from "astro-themes";

import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Navbar from "../components/Nav.astro";
import GoogleAnalytics from "../components/GoogleAnalytics.astro";

import "@fontsource/geist-sans/400.css";
import "@fontsource/geist-sans/600.css";
import "@fontsource/geist-mono/400.css";
import "@fontsource/geist-mono/600.css";
import "@styles/global.css";

const { title, description, image } = Astro.props;
---

<html lang="en" class="scrollbar-hide">
  <head>
    <ClientRouter />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="googlebot"
      content="index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <Themes />
    <BaseHead title={title} description={description} image={image} />
    <GoogleAnalytics />
  </head>
  <body
    class="font-sans antialiased flex flex-col items-center justify-center mx-auto mb-20 lg:mb-40
    scrollbar-hide relative">
    <!-- Animated gradient background - concentrated at top -->
    <div class="absolute left-0 right-0 top-0 h-screen -z-10 overflow-hidden pointer-events-none gradient-container" style="will-change: contents;">
      <!-- Light mode: top gradient (static on mobile, animated on sm+) -->
      <div class="gradient-top absolute top-0 left-0 right-0 h-96 bg-gradient-to-b from-tangerine/25 via-creamsicle/15 to-transparent dark:from-tangerine/40 dark:via-solar/30 dark:to-transparent"></div>
      <!-- Light mode: right side glow (hidden on mobile) -->
      <div class="hidden sm:block gradient-right absolute top-0 right-0 w-96 h-96 bg-gradient-to-bl from-creamsicle/35 to-transparent dark:from-tangerine/50 rounded-full blur-3xl"></div>
      <!-- Dark mode: left side glow (hidden on mobile) -->
      <div class="hidden sm:block gradient-left absolute top-20 left-0 w-80 h-80 bg-gradient-to-br from-sapphire/30 to-transparent dark:from-solar/40 rounded-full blur-3xl"></div>
    </div>
    <main
      class="flex-auto min-w-0 mt-2 lg:mt-8 flex flex-col px-6 sm:px-4 md:px-0 max-w-[640px] w-full"
      style="padding-left: max(1.5rem, env(safe-area-inset-left)); padding-right: max(1.5rem, env(safe-area-inset-right));">
      <Navbar />
      <slot />
      <Footer />
    </main>
    <style>
      /* CSS rules for the page scrollbar */
      .scrollbar-hide::-webkit-scrollbar {
        display: none;
      }

      .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }

      /* Gradient animations - static on mobile, animated on sm+ */
      .gradient-top {
        animation: none;
        will-change: opacity;
      }

      .gradient-right,
      .gradient-left {
        animation: none;
        will-change: opacity;
      }

      @media (min-width: 640px) {
        .gradient-top {
          animation: slowPulse 6s ease-in-out infinite;
        }

        .gradient-right {
          animation: slowPulse 8s ease-in-out infinite 1s;
        }

        .gradient-left {
          animation: slowPulse 7s ease-in-out infinite 2s;
        }
      }
    </style>
  </body>
</html>
